# Copy to .env and fill in. Loaded automatically via python-dotenv at startup.

# Anthropic API — optional. If unset, the agent stubs replies with a visible
# "[stub reply from Customer Support — set ANTHROPIC_API_KEY …]" message so
# routing still works end-to-end without a key.
ANTHROPIC_API_KEY=

# Port the FastAPI process (chat server + embedded agent) listens on.
PORT=8000
