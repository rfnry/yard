# Copy to .env and uncomment / edit values. Vite loads .env automatically
# for every variable prefixed with VITE_ (accessible as import.meta.env.*).

# Override the chat server URL the React app connects to.
# Default: http://localhost:8000
# VITE_CHAT_SERVER_URL=http://localhost:8000

# Override the webhook URL where the React app POSTs /alert-user.
# Default: http://localhost:9100
# VITE_AGENT_WEBHOOK_URL=http://localhost:9100
