# Anthropic API — required for real model calls. If unset, the server boots
# with a mock provider that echoes a stub reply (useful for shape-testing
# without burning tokens).
ANTHROPIC_API_KEY=

# FastAPI port (each rfnry/ example runs on its own port so they can run
# in parallel: customer-support=8101, multi-tenant=8102, stock-assistant=8103).
PORT=8101

# Anthropic model id. Defaults to claude-sonnet-4-6.
ANTHROPIC_MODEL=claude-sonnet-4-6
